// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  fullName     String?  @map("full_name") @db.VarChar(255)
  phone        String?  @db.VarChar(20)
  address      String?  @db.Text
  role         String   @default("customer") @db.VarChar(20)
  avatarUrl    String?  @map("avatar_url") @db.VarChar(500)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  orders          Order[]
  tireInspections TireInspection[]
  adminLogs       AdminLog[]
  refreshTokens   RefreshToken[]

  @@map("users")
}

model Category {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  imageUrl    String?  @map("image_url") @db.VarChar(500)
  parentId    String?  @map("parent_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  parent   Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToCategory")
  products Product[]

  @@map("categories")
}

model Product {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId    String?  @map("category_id") @db.Uuid
  sku           String   @unique @db.VarChar(100)
  name          String   @db.VarChar(255)
  slug          String   @unique @db.VarChar(255)
  description   String?  @db.Text
  price         Decimal  @db.Decimal(12, 2)
  salePrice     Decimal? @map("sale_price") @db.Decimal(12, 2)
  stockQuantity Int      @default(0) @map("stock_quantity")

  // Thông số lốp DRC
  size        String? @db.VarChar(50)
  rimDiameter Int?    @map("rim_diameter")
  loadIndex   String? @map("load_index") @db.VarChar(10)
  speedRating String? @map("speed_rating") @db.VarChar(5)
  tireType    String? @map("tire_type") @db.VarChar(50)

  // AI metadata
  aiLabel String? @map("ai_label") @db.VarChar(100)

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  category   Category?      @relation(fields: [categoryId], references: [id])
  images     ProductImage[]
  orderItems OrderItem[]

  @@map("products")
}

model ProductImage {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  cloudinaryId String   @map("cloudinary_id") @db.VarChar(300)
  url          String   @db.VarChar(500)
  altText      String?  @map("alt_text") @db.VarChar(255)
  isPrimary    Boolean  @default(false) @map("is_primary")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Order {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  orderNumber    String   @unique @map("order_number") @db.VarChar(50)
  status         String   @default("pending") @db.VarChar(30)

  subtotal       Decimal  @db.Decimal(12, 2)
  discountAmount Decimal  @default(0) @map("discount_amount") @db.Decimal(12, 2)
  shippingFee    Decimal  @default(0) @map("shipping_fee") @db.Decimal(12, 2)
  totalAmount    Decimal  @map("total_amount") @db.Decimal(12, 2)

  shippingName    String? @map("shipping_name") @db.VarChar(255)
  shippingPhone   String? @map("shipping_phone") @db.VarChar(20)
  shippingAddress String? @map("shipping_address") @db.Text

  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user     User        @relation(fields: [userId], references: [id])
  items    OrderItem[]
  payments Payment[]

  @@map("orders")
}

model OrderItem {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId    String  @map("order_id") @db.Uuid
  productId  String  @map("product_id") @db.Uuid
  quantity   Int
  unitPrice  Decimal @map("unit_price") @db.Decimal(12, 2)
  totalPrice Decimal @map("total_price") @db.Decimal(12, 2)
  snapshot   Json?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Payment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId       String   @map("order_id") @db.Uuid
  method        String   @db.VarChar(30)
  status        String   @default("pending") @db.VarChar(30)
  amount        Decimal  @db.Decimal(12, 2)

  // MoMo specific
  momoOrderId   String?  @map("momo_order_id") @db.VarChar(100)
  momoTransId   String?  @map("momo_trans_id") @db.VarChar(100)
  momoRequestId String?  @map("momo_request_id") @db.VarChar(100)
  momoPayUrl    String?  @map("momo_pay_url") @db.VarChar(500)
  momoResponse  Json?    @map("momo_response")

  paidAt    DateTime? @map("paid_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model TireInspection {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String   @map("user_id") @db.Uuid

  // Ảnh upload
  imageCloudinaryId String?  @map("image_cloudinary_id") @db.VarChar(300)
  imageUrl          String?  @map("image_url") @db.VarChar(500)

  // Kết quả AI
  wearLevel         String?  @map("wear_level") @db.VarChar(30)
  wearPercentage    Decimal? @map("wear_percentage") @db.Decimal(5, 2)
  tireTypeDetected  String?  @map("tire_type_detected") @db.VarChar(100)
  crackDetected     Boolean  @default(false) @map("crack_detected")
  crackSeverity     String?  @map("crack_severity") @db.VarChar(20)
  crackLocations    Json?    @map("crack_locations")

  aiConfidence      Decimal? @map("ai_confidence") @db.Decimal(5, 4)
  aiRawResult       Json?    @map("ai_raw_result")
  recommendation    String?  @db.Text

  // Sản phẩm gợi ý
  suggestedProducts String[] @map("suggested_products") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id])

  @@map("tire_inspections")
}

model AdminLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminId    String   @map("admin_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityType String?  @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.Uuid
  oldData    Json?    @map("old_data")
  newData    Json?    @map("new_data")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  admin User @relation(fields: [adminId], references: [id])

  @@map("admin_logs")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}
