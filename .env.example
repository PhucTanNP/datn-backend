MOMO_PARTNER_CODE=MOMO_ATM
MOMO_ACCESS_KEY=xxxxx
MOMO_SECRET_KEY=xxxxx
MOMO_REDIRECT_URL=http://localhost:3000/checkout/result
MOMO_IPN_URL=http://localhost:3001/api/v1/payments/momo/ipn

AI_SERVICE_URL=http://localhost:8000
